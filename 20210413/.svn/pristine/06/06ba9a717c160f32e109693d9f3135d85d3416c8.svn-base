#!/bin/bash
#
# 2021-03-22 王君雷
# 本shell脚本 只会被程序调用一次 然后会被调用者删除掉
#
# 1）对于通过母盘重新制作的情况 会被开机启动程序调用
# 2）对于已出货通过升级包升级的情况 会被升级脚本in.sh out.sh调用
#

filename="/etc/php5/php.ini"
zlib_file1="/initrd/abin/zlib.so"
zlib_file2="/usr/local/php5/lib/zlib.so"

if [ -f ${filename} ];then
    findzlibso=`cat ${filename} | grep "zlib\.so"`
    if [ -z "${findzlibso}" ]; then
        total=`sed -n "/^extension_dir/p" ${filename} |wc -l`
        if [ $total -eq 1 ];then
            sed -i "/^extension_dir/a\extension = ${zlib_file2}" ${filename}
            echo "$0 insert zlib.so ok"
        else
            echo "$0 not find extension_dir"
        fi
    else
        echo "$0 find zlib.so"
    fi
fi

if [ -f ${zlib_file1} ];then
    if [ -f ${zlib_file2} ];then
        echo "${zlib_file2} already exist"
    else
        echo "mv ${zlib_file1} to ${zlib_file2}"
    fi
    mv ${zlib_file1} ${zlib_file2}
else
    echo "$0 not find ${zlib_file1}"
fi

#解决SNMP获取不到磁盘使用率信息的BUG 20210729 wangjunlei
sed -i 's/#disk/disk/g' /etc/snmp/snmpd.conf.bak
cat /proc/mounts > /etc/mtab
