LIBIEC_HOME=./libiec61850-0.9.2.1

PROJECT_BINARY_NAME = sv_des
PROJECT_SOURCES = sv_des.c

include $(LIBIEC_HOME)/make/target_system.mk
include $(LIBIEC_HOME)/make/stack_includes.mk

all:	$(PROJECT_BINARY_NAME)

include $(LIBIEC_HOME)/make/common_targets.mk

LDLIBS += -lm
CFLAGS += -I$(LIBIEC_HOME)/src/mms/iso_mms/asn1c -I$(LIBIEC_HOME)/src/sampled_values

CP = cp

OBJS = $(patsubst %.c, %.o, $(PROJECT_SOURCES))

$(PROJECT_BINARY_NAME): LIBA $(OBJS)
	$(CC) $(LDFLAGS) -o $(PROJECT_BINARY_NAME) $(OBJS) $(LIB_NAME) $(LDLIBS)

%.o: %.c
	$(CC) -Wall -O2 -c $< -o $@ $(CFLAGS) $(LDFLAGS) $(INCLUDES)

LIBA:
	@cd $(LIBIEC_HOME); make -s

clean:
	rm -f $(PROJECT_BINARY_NAME)
	rm -f *.o

distclean: clean
	cd $(LIBIEC_HOME); make clean
