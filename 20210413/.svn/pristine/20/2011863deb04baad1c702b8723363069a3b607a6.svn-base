#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/ioctl.h>
#include <errno.h>
#include "lcdmanager.h"
#include "fileoperator.h"
#include "debugout.h"
#include "lcdanmit.h"
#include "lcdnexcom.h"
#include "lcdrld.h"

extern bool g_rulechange;
extern int g_last_recv;
extern int g_linklan;

#define STATUS_RUN    "Status:Run..."
#define STATUS_ERROR  "Status:In Err"
#define STATUS_NORMAL "Status:Normal"

enum flag {
    FLAG_NO_USE = 0,
    FLAG_ANMIT,
    FLAG_NEXCOM,
    FLAG_RLD,
};

float get_cpu_info(void);
float get_mem_info(void);

LCDMANAGER::LCDMANAGER(void)
{
    m_worker = NULL;
    m_lcdflag_in = m_lcdflag_out = FLAG_NO_USE;
    m_inipnum = m_outipnum = m_inbondipnum = m_outbondipnum = 0;
    m_is_inside = (DEVFLAG[0] == 'I');

    for (int i = 0; i < LCD_MAX_IP_NUM; i++) {
        m_inip[i] = new char[LCD_MAX_IP_LEN];
        memset(m_inip[i], 0, LCD_MAX_IP_LEN);
        m_outip[i] = new char[LCD_MAX_IP_LEN];
        memset(m_outip[i], 0, LCD_MAX_IP_LEN);
        m_inbondip[i] = new char[LCD_MAX_IP_LEN];
        memset(m_inbondip[i], 0, LCD_MAX_IP_LEN);
        m_outbondip[i] = new char[LCD_MAX_IP_LEN];
        memset(m_outbondip[i], 0, LCD_MAX_IP_LEN);
    }

    BZERO(m_lcdbuf);
    BZERO(m_wk);
    BZERO(m_linkstatus);
    BZERO(m_manip);
    BZERO(m_manipv6);
    strcpy(m_linkstatus, STATUS_RUN);
    m_recvpkts = 0;
}

LCDMANAGER::~LCDMANAGER(void)
{
    for (int i = 0; i < LCD_MAX_IP_NUM; ++i) {
        if (m_inip[i] != NULL) {
            delete [](m_inip[i]);
        }

        if (m_outip[i] != NULL) {
            delete [](m_outip[i]);
        }

        if (m_inbondip[i] != NULL) {
            delete [](m_inbondip[i]);
        }

        if (m_outbondip[i] != NULL) {
            delete [](m_outbondip[i]);
        }
    }
    DELETE(m_worker);
}

/**
 * [LCDMANAGER::read_flag 读取LCDFlag，把读取结果保存到成员变量]
 * @return  [成功返回true]
 */
bool LCDMANAGER::read_flag(void)
{
    CFILEOP fileop;
    if (fileop.OpenFile(SYSINFO_CONF, "r") != E_FILE_OK) {
        PRINT_ERR_HEAD
        print_err("open file error[%s]", SYSINFO_CONF);
        return false;
    }

    fileop.ReadCfgFile("SYSTEM", "LCDFlag", m_lcdbuf, sizeof(m_lcdbuf));
    printf("lcdflag is [%s]\n", m_lcdbuf);
    PRINT_DBG_HEAD
    print_dbg("lcd flag is [%s]", m_lcdbuf);

    if (strcmp(m_lcdbuf, "anmit") == 0) {
        m_lcdflag_in = FLAG_ANMIT;
    } else if (strcmp(m_lcdbuf, "anmit2") == 0) {
        m_lcdflag_in = m_lcdflag_out = FLAG_ANMIT;
    } else if (strcmp(m_lcdbuf, "nexcom") == 0) {
        m_lcdflag_in = FLAG_NEXCOM;
    } else if (strcmp(m_lcdbuf, "nexcom2") == 0) {
        m_lcdflag_in = m_lcdflag_out = FLAG_NEXCOM;
    } else if (strcmp(m_lcdbuf, "rld") == 0) {
        m_lcdflag_in = FLAG_RLD;
    } else if (strcmp(m_lcdbuf, "rld2") == 0) {
        m_lcdflag_in = m_lcdflag_out = FLAG_RLD;
    } else {
    }
    fileop.CloseFile();
    return true;
}

/**
 * [LCDMANAGER::use_lcd 是否需要进行LCD展示]
 * @return  [需要返回true]
 */
bool LCDMANAGER::use_lcd(void)
{
    return (m_is_inside ? (m_lcdflag_in != FLAG_NO_USE) : (m_lcdflag_out != FLAG_NO_USE));
}

/**
 * [LCDMANAGER::current_flag 返回当前使用的LCD类型]
 * @return  [LCD类型]
 */
int LCDMANAGER::current_flag(void)
{
    return (m_is_inside ? m_lcdflag_in : m_lcdflag_out);
}

/**
 * [LCDMANAGER::init 初始化操作]
 * @return  [初始化成功返回true]
 */
bool LCDMANAGER::init(void)
{
    DELETE(m_worker);
    if (current_flag() == FLAG_ANMIT) {
        m_worker = new LCDANMIT();
    } else if (current_flag() == FLAG_NEXCOM) {
        m_worker = new LCDNEXCOM();
    } else if (current_flag() == FLAG_RLD) {
        m_worker = new LCDRLD();
    }
    if (m_worker == NULL) {
        PRINT_ERR_HEAD
        print_err("lcd new worker error. currentflag %d", current_flag());
        return false;
    }

    PRINT_DBG_HEAD
    print_dbg("new worker over. currentflag %d", current_flag());
    return m_worker->init();
}

/**
 * [LCDMANAGER::read_info 从文件读取要展示的内容]
 */
void LCDMANAGER::read_info(void)
{
    CFILEOP fileop;
    char tmp[500] = {0};
    char tmpkey[100] = {0};

    //读工作模式
    if (fileop.OpenFile(SYSSET_CONF, "r") != E_FILE_OK) {
        PRINT_ERR_HEAD
        print_err("open file error[%s]", SYSSET_CONF);
        return;
    }
    fileop.ReadCfgFile("SYSTEM", "WorkFlag", tmp, sizeof(tmp));
    if (strcmp(tmp, "0") == 0) {        //透明
        strcpy(m_wk, "Transparent");
    } else if (strcmp(tmp, "1") == 0) { //代理
        strcpy(m_wk, "Proxy     ");
    } else if (strcmp(tmp, "2") == 0) { //路由
        strcpy(m_wk, "Route     ");
    } else {
        strcpy(m_wk, "Unknown   ");
    }

    //读管理IP
    fileop.ReadCfgFile("SYSTEM", "CSIP", m_manip, sizeof(m_manip));
    fileop.ReadCfgFile("SYSTEM", "CSIPv6", m_manipv6, sizeof(m_manipv6));
    fileop.CloseFile();

    //读IP
    if (fileop.OpenFile(DEV_CONF, "r") != E_FILE_OK) {
        PRINT_ERR_HEAD
        print_err("open file error[%s]", DEV_CONF);
        return;
    }

    fileop.ReadCfgFile("DEV", "INNET_IPNum", tmp, sizeof(tmp));
    m_inipnum = (atoi(tmp) < LCD_MAX_IP_NUM ? atoi(tmp) : LCD_MAX_IP_NUM);

    PRINT_DBG_HEAD
    print_dbg("inipnum:%d", m_inipnum);

    for (int i = 0; i < m_inipnum; i++) {
        sprintf(tmpkey, "MYIP%d", i);
        fileop.ReadCfgFile("INNET", tmpkey, m_inip[i], LCD_MAX_IP_LEN);
        PRINT_DBG_HEAD
        print_dbg("innet ip [%s]", m_inip[i]);
    }

    fileop.ReadCfgFile("DEV", "OUTNET_IPNum", tmp, sizeof(tmp));
    m_outipnum = (atoi(tmp) < LCD_MAX_IP_NUM ? atoi(tmp) : LCD_MAX_IP_NUM);

    PRINT_DBG_HEAD
    print_dbg("outipnum:%d", m_outipnum);

    for (int i = 0; i < m_outipnum; i++) {
        sprintf(tmpkey, "MYIP%d", i);
        fileop.ReadCfgFile("OUTNET", tmpkey, m_outip[i], LCD_MAX_IP_LEN);
        PRINT_DBG_HEAD
        print_dbg("outnet ip [%s]", m_outip[i]);
    }
    fileop.CloseFile();

    //读bond IP
    if (fileop.OpenFile(BONDING_CONF, "r") != E_FILE_OK) {
        PRINT_ERR_HEAD
        print_err("open file error[%s]", BONDING_CONF);
        return;
    }

    fileop.ReadCfgFile("INNET", "Bond", tmp, sizeof(tmp));

    if (atoi(tmp) == 1) {
        fileop.ReadCfgFile("INNET", "IPNum", tmp, sizeof(tmp));
        m_inbondipnum = (atoi(tmp) < LCD_MAX_IP_NUM ? atoi(tmp) : LCD_MAX_IP_NUM);

        for (int i = 0; i < m_inbondipnum; i++) {
            sprintf(tmpkey, "IPAddr%d", i);
            fileop.ReadCfgFile("INNET", tmpkey, m_inbondip[i], LCD_MAX_IP_LEN);
        }
    } else {
        m_inbondipnum = 0;
    }

    memset(tmp, 0, sizeof(tmp));
    fileop.ReadCfgFile("OUTNET", "Bond", tmp, sizeof(tmp));

    if (atoi(tmp) == 1) {
        memset(tmp, 0, sizeof(tmp));
        fileop.ReadCfgFile("OUTNET", "IPNum", tmp, sizeof(tmp));
        m_outbondipnum = (atoi(tmp) < LCD_MAX_IP_NUM ? atoi(tmp) : LCD_MAX_IP_NUM);

        for (int i = 0; i < m_outbondipnum; i++) {
            sprintf(tmpkey, "IPAddr%d", i);

            memset(tmp, 0, sizeof(tmp));
            fileop.ReadCfgFile("OUTNET", tmpkey, m_outbondip[i], LCD_MAX_IP_LEN);
        }
    } else {
        m_outbondipnum = 0;
    }

    fileop.CloseFile();
    return;
}

/**
 * [LCDMANAGER::show 展示信息 展示在液晶屏第一行]
 * @param info [待展示的内容]
 */
void LCDMANAGER::show(const char *info)
{
    m_worker->show(info);
}

/**
 * [LCDMANAGER::show 展示信息 info1展示在液晶屏第一行 info2展示在液晶屏第二行]
 * @param info1 [第一行]
 * @param info2 [第二行]
 */
void LCDMANAGER::show(const char *info1, const char *info2)
{
    m_worker->show(info1, info2);
}

/**
 * [LCDMANAGER::show_inip 展示内网业务IP]
 */
void LCDMANAGER::show_inip(void)
{
    char showbuff[64] = {0};
    for (int i = 0; i < m_inipnum; i++) {
        sprintf(showbuff, "Inside IP%d:", i);
        show(showbuff, m_inip[i]);
    }
    for (int i = 0; i < m_inbondipnum; i++) {
        sprintf(showbuff, "Inside IP%d:", i + m_inipnum);
        show(showbuff, m_inbondip[i]);
    }
}

/**
 * [LCDMANAGER::show_outip 展示外网业务IP]
 */
void LCDMANAGER::show_outip(void)
{
    char showbuff[64] = {0};
    for (int i = 0; i < m_outipnum; i++) {
        sprintf(showbuff, "Outside IP%d:", i);
        show(showbuff, m_outip[i]);
    }
    for (int i = 0; i < m_outbondipnum; i++) {
        sprintf(showbuff, "Outside IP%d:", i + m_outipnum);
        show(showbuff, m_outbondip[i]);
    }
}

/**
 * [LCDMANAGER::read_recvpkt 读取内网通信卡上接收数据包个数]
 * @param  pkt [接收数据包数 出参]
 * @return     [成功返回true]
 */
bool LCDMANAGER::read_recvpkt(long long int &pkt)
{
    char buf[300] = {0};
    char ethname[20] = {0};
    sprintf(ethname, "eth%d", g_linklan);

    FILE *fp = fopen("/proc/net/dev", "r");
    if (fp == NULL) {
        PRINT_ERR_HEAD
        print_err("fopen /proc/net/dev fail.[%s]", strerror(errno));
        return false;
    }

    while (!feof(fp)) {
        memset(buf, 0, sizeof(buf));
        if (fgets(buf, sizeof(buf), fp) != NULL) {
            if (strstr(buf, ethname) != NULL) {
                sscanf(buf, "%*s%*s%lld", &pkt);
                fclose(fp);
                return true;
            }
        }
    }

    fclose(fp);
    return false;
}

/**
 * [LCDMANAGER::judge_status 判定设备状态]
 * @return  [判定成功返回true（判定成功不意味着设备状态一定正常）]
 */
bool LCDMANAGER::judge_status(void)
{
    if (m_is_inside) {
        if (difftime(time(NULL), g_last_recv) > GET_SYS_STATUS_CYCLE + 5) { //秒钟收不到数据包
            strcpy(m_linkstatus, STATUS_ERROR);
        } else {
            strcpy(m_linkstatus, STATUS_NORMAL);
        }
    } else {
        //外网侧
        long long int tmp = 0;
        if (read_recvpkt(tmp)) {
            if (tmp == m_recvpkts) {
                strcpy(m_linkstatus, STATUS_ERROR);
                PRINT_ERR_HEAD
                print_err("no change, recv pkts:%lld", tmp);
            } else {
                strcpy(m_linkstatus, STATUS_NORMAL);
                m_recvpkts = tmp;
            }
        } else { //读失败时 不改变m_linkstatus内容
            PRINT_ERR_HEAD
            print_err("read recvpkt fail");
            return false;
        }
    }

    return true;
}

/**
 * [LCDMANAGER::loop 循环展示]
 */
void LCDMANAGER::loop(void)
{
    PRINT_DBG_HEAD
    print_dbg("lcd loop begin...");

    char cpuusage[64] = {0};
    char memusage[64] = {0};

    while (1) {
        if (g_rulechange) {
            read_info();
            g_rulechange = false;
        }

        show(m_linkstatus);
        show("Work Model:", m_wk);
        show("MAN IP:", m_manip);
        if (!IS_STR_EMPTY(m_manipv6)) {
            show("MAN IP:", m_manipv6);
        }

        if (strcmp(m_wk, "Transparent") != 0) {
            if (m_is_inside) {
                show_inip();
                if (m_lcdflag_out == FLAG_NO_USE) { //如果只有内网使用了LCD 则内网LCD也需要展示外网业务IP
                    show_outip();
                }
            } else {
                show_outip();
            }
        }

        sprintf(cpuusage, "%f%%", get_cpu_info() * 100);
        show("CPU USAGE:", cpuusage);

        sprintf(memusage, "%f%%", get_mem_info() * 100);
        show("MEM USAGE:", memusage);

        judge_status();
    }
}

/**
 * [LCDThread LCD展示 线程函数]
 * @param  arg [未使用]
 * @return     [未使用]
 */
void *LCDThread(void *arg)
{
    pthread_setself("lcdmanager");
    PRINT_INFO_HEAD
    print_info("lcd show begin");

    LCDMANAGER lcdmanager;
    if (lcdmanager.read_flag()) {
        if (lcdmanager.use_lcd()) {
            if (lcdmanager.init()) {
                lcdmanager.loop();//无限循环
            } else {
                PRINT_ERR_HEAD
                print_err("lcd init error");
                printf("lcd init error\n");
            }
        } else {
            PRINT_DBG_HEAD
            print_dbg("no use lcd");
            printf("no use lcd\n");
        }
    } else {
        PRINT_ERR_HEAD
        print_err("read lcd flag error");
        printf("read lcd flag error\n");
    }
    PRINT_INFO_HEAD
    print_info("lcd thread will return");
    return NULL;
}

/**
 * [StartShowLCD 开启LCD线程]
 * @return  [成功返回true]
 */
bool StartShowLCD(void)
{
    pthread_t threadid = 0;
    if (pthread_create(&threadid, NULL, LCDThread, NULL) != 0) {
        PRINT_ERR_HEAD
        print_err("create lcd thread fail");
        return false;
    }

    return true;
}
