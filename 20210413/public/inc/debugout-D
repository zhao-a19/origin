static void print_info(const pchar fmt, ...)
{
#if __DEBUG_INFO__
    char line[MAXLINECHARS + 2] = {0};  //+2防止溢出

    print_time(line);

    {
        va_list arg;
        va_start(arg, fmt);
        vsnprintf(line + strlen(line), MAXLINECHARS - strlen(line), fmt, arg);
        va_end(arg);
    }

    strcat(line, "\n");

    //输出到管道
    fprintf(stderr, line);

#endif

}
#endif

